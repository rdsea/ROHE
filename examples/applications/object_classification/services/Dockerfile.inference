FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi uvicorn[standard] torch torchvision Pillow httpx

COPY . /app/

ARG MODEL_SERVICE=resnet50_inference
ENV MODEL_SERVICE=${MODEL_SERVICE}

EXPOSE 8000

CMD ["sh", "-c", "uvicorn ${MODEL_SERVICE}.main:app --host 0.0.0.0 --port 8000"]
