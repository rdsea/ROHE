FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi uvicorn[standard] httpx Pillow pydantic

COPY . /app/

ARG MODEL_SERVICE=yolov5l_inference
ENV MODEL_SERVICE=${MODEL_SERVICE}

EXPOSE 8000

CMD ["sh", "-c", "uvicorn ${MODEL_SERVICE}.main:app --host 0.0.0.0 --port 8000"]
